# ============================================
# SMM Bot + Mini App — environment variables
# ============================================
# Bu faylni `.env` nomiga nusxa qiling va o'z qiymatlaringizni kiriting.
# Hech qachon haqiqiy .env faylini git'ga commit qilmang!

# ---- Telegram ----
BOT_TOKEN=your_telegram_bot_token_here
ADMIN_ID=123456789
CHANNEL_USERNAME=@your_channel

# ---- JWT ----
# Kamida 32 belgidan iborat tasodifiy string (masalan: `python -c "import secrets; print(secrets.token_hex(32))"`)
JWT_SECRET_KEY=please_generate_a_random_64_char_hex_string_here_min_32_chars
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# Telegram init_data yangi bo'lish oynasi (soniya). Default 300 = 5 daqiqa.
INIT_DATA_MAX_AGE_SECONDS=300

# ---- Mini App frontend URL ----
FRONTEND_URL=https://your-mini-app.example.com

# ---- SMM Panellari ----
SMM_API_URL=https://peakerr.com/api/v2
SMM_API_KEY=
SMMMAIN_API_URL=https://smmmain.com/api/v2
SMMMAIN_API_KEY=

# ---- SMS provayderlar ----
SMS_API_KEY=
FIVESIM_API_KEY=
SMSPVA_API_KEY=

# ---- Click to'lov tizimi ----
CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=

# ---- Qo'lma-qo'l karta to'lovlari ----
# Har bir karta uchun CARD va NAME ikkalasi ham kerak. Aks holda karta ko'rsatilmaydi.
CLICK_CARD=
CLICK_NAME=
PAYME_CARD=
PAYME_NAME=
UZUM_CARD=
UZUM_NAME=
VISA_CARD=
VISA_NAME=

# ---- Database (kelajakda PostgreSQL uchun) ----
# DATABASE_URL=postgresql+asyncpg://user:pass@host/dbname
